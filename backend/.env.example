# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT CONFIGURATION - COPY TO .env AND FILL WITH REAL VALUES
# NEVER COMMIT .env FILE WITH REAL CREDENTIALS
# ═══════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Configuration ──────────────────────────────────────────────────────
# CRITICAL: Use a strong random string (32+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secure_random_secret_here_minimum_32_characters
JWT_EXPIRATION=7d

# ─── Database Configuration ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_admin
DB_PASSWORD=your_secure_database_password_here

# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
DB_URL=postgresql://ecommerce_admin:your_secure_database_password_here@localhost:5432/ecommerce_db

# ─── Security Configuration ─────────────────────────────────────────────────
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Specify allowed origins (comma-separated for production)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── Email Configuration (if needed for password reset, etc.) ─────────────────
# EMAIL_SERVICE=your_service
# EMAIL_FROM=your_email@example.com
# EMAIL_PASSWORD=your_email_password
