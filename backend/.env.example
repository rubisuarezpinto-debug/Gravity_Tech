# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT CONFIGURATION - COPY TO .env AND FILL WITH REAL VALUES
# NEVER COMMIT .env FILE WITH REAL CREDENTIALS
# ═══════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Configuration ──────────────────────────────────────────────────────
# CRITICAL: Use a strong random string (32+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secure_random_secret_here_minimum_32_characters
JWT_EXPIRATION=7d

# ─── Database Configuration ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_admin
DB_PASSWORD=your_secure_database_password_here

# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
DB_URL=postgresql://ecommerce_admin:your_secure_database_password_here@localhost:5432/ecommerce_db

# ─── Security Configuration ─────────────────────────────────────────────────
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Specify allowed origins (comma-separated for production)
# In production, set to your Vercel URL: https://tu-app.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── Deployment URLs ─────────────────────────────────────────────────────────
# Frontend URL in Vercel (used for Content-Security-Policy header)
FRONTEND_URL=https://tu-app.vercel.app

# Neon DB URL format (overrides individual DB_* vars):
# DB_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ─── Resend (Email) ──────────────────────────────────────────────────────────
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dominio verificado en Resend. En desarrollo puedes usar: onboarding@resend.dev
FROM_EMAIL=Gravity Tech <noreply@tudominio.com>
